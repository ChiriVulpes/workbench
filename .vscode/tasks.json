{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Markdown Workbench",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}/webapp"
      },
      "isBackground": true,
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".+"
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": "(?:Local:\\s+http://localhost:3002|Local:\\s+http://127\\.0\\.0\\.1:3002|ready - started server on .*3002|Ready in .*ms)"
          }
        }
      ]
    }
  ]
}
